# === Server ===
HOST=0.0.0.0
PORT=8000
KB_PATH=./kb

# === Query limits ===
MAX_RESULTS=50
MAX_QUERY_LENGTH=500

# === Rate Limiting ===
RATE_LIMIT_MAX=60
RATE_LIMIT_WINDOW=60

# === Autenticação (descomente para ativar — ver TODO.md Fase 4.3) ===
# Lista de API keys válidas, separadas por vírgula. Se vazia/ausente, a
# autenticação fica DESLIGADA (dev local e testes continuam sem exigir key).
# MCP_API_KEYS=chave-secreta-um,chave-secreta-dois

# === Google Drive (opcional — só se usar ingest_drive.py) ===
# GOOGLE_APPLICATION_CREDENTIALS=credentials.json

# === Observabilidade (opcional — ver TODO.md Fase 6.2) ===
# Token do Logfire (Pydantic). Se definido (e o pacote `logfire` instalado),
# ativa tracing OTEL dos spans nativos do FastMCP; sem ele, apenas os logs
# JSON estruturados (sempre ligados) ficam disponíveis.
# LOGFIRE_TOKEN=
