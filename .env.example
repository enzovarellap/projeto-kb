# === Server ===
HOST=0.0.0.0
PORT=8000
KB_PATH=./kb

# === Query limits ===
MAX_RESULTS=50
MAX_QUERY_LENGTH=500

# === Rate Limiting ===
RATE_LIMIT_MAX=60
RATE_LIMIT_WINDOW=60

